          (".*scratch.*" . ((?w . scratch) (?t . scratch2)))))

  (moder-define-keys 'beacon
    '("M" . moder-beacon-apply-next-command))

  (moder-motion-define-key
   '("j" . moder-next)
   '("k" . moder-prev)
   '("<escape>" . ignore))
  (moder-leader-define-key
   ;; Use SPC (0-9) for digit arguments.
