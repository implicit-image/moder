  (setq moder-cheatsheet-layout moder-cheatsheet-layout-qwerty)
  (setq moder-mode-local-char-thing-table-alist
        '(
          ;; (emacs-lisp-mode . ((?j . test) (?d . override)))
          (c-mode . ((?g . c-thing))))
        moder-buffer-local-char-thing-table-alist
        '( ;; THING only for special mode
          ((derived-mode . special-mode) . ((?s . special-thing)))
          ;; THING only for buffers with predicate
          ((lambda (buffer &rest args) (treesit-parser-list))
           . ((?t . treesit-thing)
              (?d . treesit-def)))
          ;; THING for a particular buffer
          (".*scratch.*" . ((?w . scratch) (?t . scratch2)))))

  (moder-define-keys 'beacon
    '("M" . moder-beacon-apply-next-command))

  (moder-motion-define-key
   '("j" . moder-next)
   '("k" . moder-prev)
   '("<escape>" . ignore))
  (moder-leader-define-key
   ;; Use SPC (0-9) for digit arguments.
   '("1" . moder-digit-argument)
   '("2" . moder-digit-argument)
   '("3" . moder-digit-argument)
   '("4" . moder-digit-argument)
   '("5" . moder-digit-argument)
   '("6" . moder-digit-argument)
